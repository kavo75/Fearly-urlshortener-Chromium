{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "description": "__MSG_ext_description__",
  "version": "1.0.0",
  "default_locale": "en",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "https://www.fearly.eu/*",
    "https://fearly.eu/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "__MSG_ext_name__"
  },

  "options_page": "settings.html",

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
